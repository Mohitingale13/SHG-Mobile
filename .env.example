# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000

# ─── Database ────────────────────────────────────────────────────────────────
# SUPABASE_DATABASE_URL takes priority over DATABASE_URL when both are present.
# Use this to point explicitly to your Supabase database without touching
# Replit's managed DATABASE_URL.
#
# Supabase – use the "Transaction" pooler URI from:
#   Supabase Dashboard → Project → Settings → Database → Connection string → URI
# SUPABASE_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# DATABASE_URL is managed automatically by Replit's database integration.
# Leave it unset locally — SUPABASE_DATABASE_URL will be used instead.
# Without either variable the app runs with in-memory storage (data resets on restart).

# ─── NLP (Voice Assistant) ───────────────────────────────────────────────────
# Get a free API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ─── Android APK / Native Build ──────────────────────────────────────────────
# Set this to your deployed backend URL before building the Android APK.
# Leave empty (or unset) for web — relative paths are used automatically.
# Must NOT have a trailing slash.
# Example (Replit deployment):
# EXPO_PUBLIC_API_URL=https://shg-records.replit.app
# Example (local LAN testing):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:5000
EXPO_PUBLIC_API_URL=
